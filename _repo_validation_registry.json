      "group": "governance",
      "owner": "repo-maintainers",
      "scope": "repository governance",
      "ciInvocation": "MATRIX_ONLY",
      "findingProtocol": "VALIDATION_FINDING",
      "enabled": true,
      "rationale": "The registry and execution matrix must cover every validator, profile, severity, entrypoint, and CI invocation rule."
