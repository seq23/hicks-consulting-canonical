{
  "schemaVersion": "1.0.0",
  "repo": "hicks-consulting-canonical",
  "authority": "docs/runbooks/VALIDATION_REGISTRY.md",
  "policy": {
    "findingMarker": "VALIDATION_FINDING",
    "unexpectedExecutionFailure": "HARD_FAIL",
    "syntaxFailure": "HARD_FAIL",
    "signalTermination": "HARD_FAIL",
    "unexpectedStderr": "HARD_FAIL",
    "directCiLeafInvocation": "FORBIDDEN",
    "severityDefinitions": {
      "HARD_FAIL": {
        "blocksRelease": true,
        "description": "Direct safety, data-loss, compliance, deployment, publication-boundary, or repository-write risk."
      },
      "STRONG_WARNING": {
        "blocksRelease": false,
        "description": "Material user, conversion, discoverability, content-governance, or operator defect requiring prompt repair."
      },
      "SOFT_WARNING": {
        "blocksRelease": false,
        "description": "Quality, resilience, optimization, or cleanup defect."
      },
      "INFO": {
        "blocksRelease": false,
        "description": "Observability or optional planning signal with no warning annotation."
      }
    }
  },
  "releaseGates": [
    {
      "id": "dependency-install",
      "command": "npm ci",
      "severity": "HARD_FAIL",
      "owner": "repo-maintainers",
      "rationale": "A lockfile install failure prevents deterministic execution."
    },
    {
      "id": "production-build",
      "command": "npm run build",
      "severity": "HARD_FAIL",
      "owner": "repo-maintainers",
      "rationale": "A failed production build is a deployment blocker."
    }
  ],
