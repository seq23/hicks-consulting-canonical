    "ingestion": {
      "description": "Content-intelligence ingestion, observability, provider-resilience, and publishing-governance checks.",
      "checks": [
        "source-health",
        "ingestion-freshness",
        "query-signal-schema",
        "query-clusters",
        "fanout-candidates",
        "social-firehose",
        "throttle-contract",
        "content-briefs"
      ]
    },
    "sitemap-indexing": {
      "description": "Crawler, sitemap, and hidden LLM surface checks for the indexing workflow.",
      "checks": [
        "sitemap-parity",
        "hidden-llm-surfaces",
        "llm-ingestion-routes"
      ]
    },
    "indexnow": {
      "description": "IndexNow contract check after emission.",
      "checks": [
        "indexnow"
      ]
    },
    "agency": {
      "description": "Agency dashboard infrastructure plus warning-only SEO/AEO/GEO and forward publishing-readiness checks.",
      "checks": [
        "agency-infrastructure",
        "agency-quality"
      ]
    },
    "digital-products": {
      "description": "Digital product catalog, public routes, admin upload flow, and cover fallback checks.",
      "checks": [
        "digital-products-contract",
        "product-routes",
        "product-upload-contract",
        "product-cover-contract",
        "product-api-behavior"
      ]
    }
  },
  "compositeScripts": {
    "validate:all": "all",
    "validate:ingestion": "ingestion",
    "validate:profile:sitemap-indexing": "sitemap-indexing",
    "validate:profile:indexnow": "indexnow",
    "validate:profile:agency": "agency",
    "validate:profile:digital-products": "digital-products"
  }
